# ── Server Environment Variables ──────────────────────────────
# Copy this file to .env in the server/ directory and fill in real values.

PORT=8787

# ── AI Providers ──────────────────────────────────────────────
# Get a Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Optional – enables Claude as primary AI for explain-match
# Get a Claude key at: https://console.anthropic.com/
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Google Maps ──────────────────────────────────────────────
# FIX: Required by the frontend map component.
# Get a key at: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Auth ──────────────────────────────────────────────────────
# IMPORTANT: Change this to a 64-char random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-64-char-random-string-in-production
JWT_EXPIRES_IN=8h

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=20

# ── CORS ──────────────────────────────────────────────────────
# Set this to your frontend's domain in production.
# For multiple origins, see: https://expressjs.com/en/resources/middleware/cors.html
CORS_ORIGIN=http://localhost:5173

# ── Cache ─────────────────────────────────────────────────────
MATCH_CACHE_TTL_MS=300000
MATCH_CACHE_MAX_SIZE=500
