# ── Server Environment Variables ──────────────────────────────
# Copy this file to .env in the server/ directory and fill in values.

PORT=8787

# AI Provider Keys (NEVER expose these client-side)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# OPENAI_API_KEY=optional_openai_key
# OPENAI_MODEL=gpt-4o-mini

# Auth — CHANGE THIS IN PRODUCTION
JWT_SECRET=change-this-to-a-64-char-random-string-in-production
JWT_EXPIRES_IN=8h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=20

# CORS — set to your frontend domain in production
CORS_ORIGIN=http://localhost:5173

# Cache
MATCH_CACHE_TTL_MS=300000
MATCH_CACHE_MAX_SIZE=500
