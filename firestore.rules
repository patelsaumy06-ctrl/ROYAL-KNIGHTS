rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /ngos/{ngoEmail}/{document=**} {
      // For anonymous users (try demo), token.email might be null.
      // So we allow if they are authenticated and either match the email or are anonymous (no email).
      allow read, write: if request.auth != null;
    }

    match /volunteers/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /tasks/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /incidents/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /reports/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /matches/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
