rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to safely check ownership for both real and anonymous (Demo) users
    function isOwner(emailField) {
      return request.auth != null && (
        ('email' in request.auth.token && emailField == request.auth.token.email) ||
        (!('email' in request.auth.token) && emailField.matches('guest_.*@Needlink\\.org'))
      );
    }

    // ─── DEFAULT: deny everything unless explicitly allowed ───────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── NGOs ─────────────────────────────────────────────────────────────────
    // Each NGO can only read/write their own data, keyed by their email.
    // Anonymous users are sandboxed to 'guest_...' profiles.
    match /ngos/{ngoEmail}/{document=**} {
      allow read, write: if isOwner(ngoEmail);
    }

    // ─── VOLUNTEERS ───────────────────────────────────────────────────────────
    // Volunteers are managed by NGOs — no public access.
    // Any authenticated NGO user can read all volunteers (needed for matching).
    // Only authenticated users can create/update/delete volunteer records.
    match /volunteers/{volunteerId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name', 'skills', 'region']);
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ─── TASKS ────────────────────────────────────────────────────────────────
    // Tasks are created and owned by NGOs.
    // Any authenticated user can read tasks (volunteers need to see assignments).
    // Only the NGO that created a task can update or delete it.
    match /tasks/{taskId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['title', 'region', 'createdBy'])
                    && isOwner(request.resource.data.createdBy);
      allow update, delete: if request.auth != null
                            && isOwner(resource.data.createdBy);
    }

    // ─── REPORTS ─────────────────────────────────────────────────────────────
    // Reports are generated by NGOs and are private to them.
    // Only the NGO that created a report can read or modify it.
    match /reports/{reportId} {
      allow read, write: if request.auth != null
                         && isOwner(resource.data.createdBy);
      allow create: if request.auth != null
                    && isOwner(request.resource.data.createdBy);
    }

    // ─── MATCHES ─────────────────────────────────────────────────────────────
    // Keep matches accessible so the frontend engine can read results
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── INCIDENTS ───────────────────────────────────────────────────────────
    match /incidents/{incidentId} {
      allow read, write: if request.auth != null;
    }

  }
}
